  "descricao": "Cloud Core Router 1009-7G-1C-1S+ — 1U rackmount, 7x Gigabit Ethernet, 1x Combo, 1x SFP+, 9 cores x 1.2GHz, 2GB RAM",
  "capabilities": [
    {
      "id": "ping",
      "label": "Ping / Disponibilidade",
      "descricao": "Verifica se o equipamento está online via ICMP",
      "categoria": "Básico",
      "requer_discovery": false,
      "itens": [
        {
          "id": "icmp_ping",
          "nome": "ICMP Ping",
          "tipo": "ICMP_PING",
          "unidade": "",
          "descricao": "Online=1 / Offline=0",
          "triggers": [
            {
              "id": "host_offline",
              "nome": "Host offline",
              "condicao": "=",
              "threshold": 0,
              "severidade": "high",
              "auto_create": true,
              "mensagem": "Host {host} não responde ao ping — equipamento offline"
            }
          ]
        },
        {
          "id": "icmp_loss",
          "nome": "Perda de Pacotes",
          "tipo": "ICMP_LOSS",
          "unidade": "%",
          "descricao": "Percentual de pacotes perdidos",
          "triggers": [
            {
              "id": "icmp_loss_warning",
              "nome": "Perda de pacotes alta",
              "condicao": ">=",
              "threshold": 20,
              "severidade": "warning",
              "auto_create": true,
              "mensagem": "Host {host}: perda de {valor}% dos pacotes ICMP"
            },
            {
              "id": "icmp_loss_critical",
              "nome": "Perda de pacotes crítica",
              "condicao": ">=",
              "threshold": 50,
              "severidade": "critical",
              "auto_create": true,
              "mensagem": "Host {host}: perda CRÍTICA de {valor}% dos pacotes — link instável"
            }
          ]
        },
        {
          "id": "icmp_response",
          "nome": "Tempo de Resposta",
          "tipo": "ICMP_RESPONSE",
          "unidade": "ms",
          "descricao": "Latência ICMP em milissegundos",
          "triggers": [
            {
              "id": "latencia_alta",
              "nome": "Latência alta",
              "condicao": ">=",
              "threshold": 150,
              "severidade": "warning",
              "auto_create": true,
              "mensagem": "Host {host}: latência de {valor}ms (limite: 150ms)"
            }
          ]
        }
      ]
    },
    {
      "id": "cpu",
      "label": "CPU",
      "descricao": "Utilização por core — 9 cores (index 1-9)",
